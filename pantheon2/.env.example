# Pantheon 2.0 Environment Variables
# Copy this file to .env and fill in your values
# NEVER commit .env to version control

# --- Supabase ---
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# --- LLM Providers (only the ones you use) ---
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=
# LM Studio: no key needed, just set lmstudio provider in harness.config.json

# --- Hardware ---
PLAUD_BLE_DEVICE_ID=           # BLE device name or MAC address for Plaud Note Pro
SLM_MODEL_PATH=./models/phi-3-mini-4k-instruct-q4_k_m.gguf

# --- App ---
ENVIRONMENT=development         # development | staging | production
LOG_LEVEL=INFO
SESSION_LOG_RETENTION_DAYS=730  # 24 months
